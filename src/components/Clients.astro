---
// Clients Section Component - Logo Slider
const clients = Array.from({ length: 40 }, (_, i) => ({
  id: i + 1,
  logo: `/images/clients/${i + 1}.png`,
  name: `Client ${i + 1}`
}));
---

<section id="clients" class="py-16 md:py-24 bg-white overflow-hidden">
  <div class="container-custom">
    <div class="text-center space-y-4 mb-12">
      <h2 class="text-3xl md:text-4xl lg:text-5xl font-bold text-gray-900">
        Telah Dipercaya Oleh Perusahaan Multinasional Seluruh Indonesia
      </h2>
      <p class="text-lg text-gray-600 max-w-2xl mx-auto">
        Kami bangga menjadi mitra terpercaya dalam menyediakan perlengkapan safety untuk berbagai industri di Indonesia
      </p>
    </div>
  </div>

  <!-- Logo Slider -->
  <div class="relative">
    <!-- Gradient Overlays -->
    <div class="absolute left-0 top-0 bottom-0 w-24 bg-gradient-to-r from-white to-transparent z-10 pointer-events-none"></div>
    <div class="absolute right-0 top-0 bottom-0 w-24 bg-gradient-to-l from-white to-transparent z-10 pointer-events-none"></div>

    <!-- Slider Container -->
    <div class="slider-container">
      <div class="slider-track">
        <!-- First set of logos -->
        {clients.map((client) => (
          <div class="slider-item">
            <div class="bg-gray-50 hover:bg-white rounded-xl p-6 flex items-center justify-center transition-all duration-300 hover:shadow-lg border border-gray-100 hover:border-primary-200 h-full">
              <img
                src={client.logo}
                alt={client.name}
                class="w-24 h-24 object-contain"
                loading="lazy"
              />
            </div>
          </div>
        ))}
        <!-- Duplicate set for seamless loop -->
        {clients.map((client) => (
          <div class="slider-item">
            <div class="bg-gray-50 hover:bg-white rounded-xl p-6 flex items-center justify-center transition-all duration-300 hover:shadow-lg border border-gray-100 hover:border-primary-200 h-full">
              <img
                src={client.logo}
                alt={client.name}
                class="w-24 h-24 object-contain"
                loading="lazy"
              />
            </div>
          </div>
        ))}
      </div>
    </div>
  </div>
</section>

<style>
  .slider-container {
    width: 100%;
    overflow: hidden;
  }

  .slider-track {
    display: flex;
    gap: 1.5rem;
    animation: scroll 60s linear infinite;
    width: max-content;
  }

  .slider-track:hover {
    animation-play-state: paused;
  }

  .slider-item {
    flex-shrink: 0;
    width: 150px;
  }

  @keyframes scroll {
    0% {
      transform: translateX(0);
    }
    100% {
      transform: translateX(-50%);
    }
  }

  @media (max-width: 768px) {
    .slider-item {
      width: 120px;
    }

    .slider-track {
      gap: 1rem;
    }
  }
</style>
