    description: 'Coverall heavy duty untuk perlindungan menyeluruh',
    descriptionEn: 'Heavy duty coverall for complete protection',
    clientName: 'PLN Persero',
    clientLogo: '/images/clients/3.png',
    image: '/images/portfolio/coverall-pln.webp',
  },
  {
