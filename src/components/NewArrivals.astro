    description: 'Rompi safety dengan material reflective grade 1',
    descriptionEn: 'Safety vest with grade 1 reflective material',
    clientName: 'Kementerian PUPR',
    clientLogo: '/images/clients/2.png',
    image: '/images/portfolio/rompi-pupr.webp',
  },
  {
    id: 6,
    productName: 'Jaket Safety Pro',
    productNameEn: 'Pro Safety Jacket',
    description: 'Jaket teknisi dengan multiple pocket untuk tools',
    descriptionEn: 'Technician jacket with multiple pockets for tools',
    clientName: 'BBWS',
    clientLogo: '/images/clients/2.png',
    image: '/images/portfolio/jaket-bbws.webp',
