---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

export async function getStaticPaths() {
  const blogPosts = await getCollection('blog');
  return blogPosts.map(post => ({
    params: { slug: post.slug },
    props: { post },
  }));
}

const { post } = Astro.props;
const { Content } = await post.render();

// Format date
const formattedDate = post.data.pubDate.toLocaleDateString('id-ID', {
  year: 'numeric',
  month: 'long',
  day: 'numeric'
});

// Get related posts (same category, exclude current)
const allPosts = await getCollection('blog');
const relatedPosts = allPosts
  .filter(p => p.data.category === post.data.category && p.slug !== post.slug)
  .slice(0, 2);
---

<BaseLayout title={`${post.data.title} - Fabrik Safety Blog`}>
  <main>
    <!-- Hero Section -->
    <section class="bg-gradient-to-r from-primary-700 to-primary-900 text-white py-16 md:py-20">
      <div class="container mx-auto px-4 md:px-6 lg:px-8">
        <div class="max-w-4xl mx-auto">
          <!-- Breadcrumb -->
          <nav class="flex items-center space-x-2 text-sm text-primary-100 mb-6">
            <a href="/" class="hover:text-white transition-colors"
              data-id="Beranda"
              data-en="Home"
            >Beranda</a>
            <span>/</span>
            <a href="/blog" class="hover:text-white transition-colors"
              data-id="Blog"
              data-en="Blog"
            >Blog</a>
            <span>/</span>
            <span class="text-white line-clamp-1">{post.data.title}</span>
          </nav>

          <!-- Category Badge -->
          <span class="inline-block bg-white/20 text-white px-4 py-1.5 rounded-full text-sm font-semibold mb-6">
            {post.data.category}
          </span>

          <!-- Title -->
          <h1 class="text-3xl md:text-4xl lg:text-5xl font-bold mb-6 leading-tight"
            data-id={post.data.title}
            data-en={post.data.titleEn}
          >{post.data.title}</h1>

          <!-- Meta Info -->
          <div class="flex flex-wrap items-center gap-4 text-primary-100">
            <div class="flex items-center gap-2">
              <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"/>
              </svg>
              <span>{post.data.author}</span>
            </div>
            <span class="hidden md:inline">•</span>
            <div class="flex items-center gap-2">
              <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"/>
              </svg>
              <time>{formattedDate}</time>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- Featured Image -->
    <section class="py-8">
      <div class="container mx-auto px-4 md:px-6 lg:px-8">
        <div class="max-w-4xl mx-auto">
          <div class="featured-image-container rounded-xl overflow-hidden shadow-xl">
            <img
              src={post.data.image}
              alt={post.data.title}
              class="w-full h-full object-cover"
              loading="lazy"
            />
          </div>
        </div>
      </div>
    </section>

    <!-- Article Content -->
    <article class="py-8 md:py-12">
      <div class="container mx-auto px-4 md:px-6 lg:px-8">
        <div class="max-w-4xl mx-auto">
          <div class="blog-content">
            <Content />
          </div>

          <!-- Tags & Share -->
          <div class="mt-12 pt-8 border-t border-gray-200">
            <!-- Tags -->
            {post.data.tags && post.data.tags.length > 0 && (
              <div class="mb-8">
                <span class="text-gray-600 font-semibold mr-3"
                  data-id="Tags:"
                  data-en="Tags:"
                >Tags:</span>
                <div class="flex flex-wrap gap-2 mt-2 inline">
                  {post.data.tags.map(tag => (
                    <span class="bg-primary-50 text-primary-700 text-sm px-4 py-1.5 rounded-full font-medium">
                      #{tag}
                    </span>
                  ))}
                </div>
              </div>
            )}

            <!-- Share Buttons -->
            <div>
              <h3 class="text-lg font-semibold text-gray-900 mb-4"
                data-id="Bagikan artikel ini:"
                data-en="Share this article:"
              >Bagikan artikel ini:</h3>
              <div class="flex gap-3">
                <a
                  href={`https://wa.me/?text=${encodeURIComponent(post.data.title + ' - ' + Astro.url.href)}`}
                  target="_blank"
                  rel="noopener noreferrer"
                  class="inline-flex items-center gap-2 bg-green-600 hover:bg-green-700 text-white px-5 py-2.5 rounded-lg transition-colors"
                  aria-label="Share on WhatsApp"
                >
                  <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24">
                    <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>
                  </svg>
                  <span>WhatsApp</span>
                </a>
                <a
                  href={`https://www.facebook.com/sharer/sharer.php?u=${encodeURIComponent(Astro.url.href)}`}
                  target="_blank"
                  rel="noopener noreferrer"
                  class="inline-flex items-center gap-2 bg-blue-600 hover:bg-blue-700 text-white px-5 py-2.5 rounded-lg transition-colors"
                  aria-label="Share on Facebook"
                >
                  <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24">
                    <path d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z"/>
                  </svg>
                  <span>Facebook</span>
                </a>
              </div>
            </div>
          </div>
        </div>
      </div>
    </article>

    <!-- Related Articles -->
    {relatedPosts.length > 0 && (
      <section class="py-12 md:py-16 bg-gray-50">
        <div class="container mx-auto px-4 md:px-6 lg:px-8">
          <div class="max-w-4xl mx-auto">
            <h2 class="text-2xl md:text-3xl font-bold text-gray-900 mb-8 text-center"
              data-id="Artikel Terkait"
              data-en="Related Articles"
            >Artikel Terkait</h2>
            <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
              {relatedPosts.map((related) => (
                <article class="bg-white rounded-xl shadow-md overflow-hidden hover:shadow-lg transition-shadow">
                  <div class="aspect-video overflow-hidden">
                    <img
                      src={related.data.image}
                      alt={related.data.title}
                      class="w-full h-full object-cover hover:scale-105 transition-transform duration-300"
                      loading="lazy"
                    />
                  </div>
                  <div class="p-6">
                    <span class="text-sm text-primary-600 font-semibold">{related.data.category}</span>
                    <h3 class="text-lg font-bold mt-2 mb-3 line-clamp-2"
                      data-id={related.data.title}
                      data-en={related.data.titleEn}
                    >{related.data.title}</h3>
                    <p class="text-gray-600 text-sm mb-4 line-clamp-2"
                      data-id={related.data.description}
                      data-en={related.data.descriptionEn}
                    >{related.data.description}</p>
                    <a href={`/blog/${related.slug}`} class="text-primary-600 font-semibold hover:text-primary-700 transition-colors">
                      <span data-id="Baca Selengkapnya" data-en="Read More">Baca Selengkapnya</span> →
                    </a>
                  </div>
                </article>
              ))}
            </div>
          </div>
        </div>
      </section>
    )}

    <!-- CTA Section -->
    <section class="py-16 bg-primary-600">
      <div class="container mx-auto px-4 md:px-6 lg:px-8 text-center">
        <h2 class="text-2xl md:text-3xl font-bold text-white mb-4"
          data-id="Butuh Pakaian Safety?"
          data-en="Need Safety Wear?"
        >Butuh Pakaian Safety?</h2>
        <p class="text-white/90 mb-8 max-w-2xl mx-auto"
          data-id="Hubungi kami sekarang untuk konsultasi gratis tentang kebutuhan pakaian safety perusahaan Anda"
          data-en="Contact us now for a free consultation about your company's safety apparel needs"
        >
          Hubungi kami sekarang untuk konsultasi gratis tentang kebutuhan pakaian safety perusahaan Anda
        </p>
        <a
          href="https://wa.me/6285111204599"
          class="inline-flex items-center gap-2 bg-white text-primary-600 font-semibold py-3 px-8 rounded-lg hover:bg-gray-100 transition-colors"
        >
          <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24">
            <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>
          </svg>
          <span data-id="Hubungi Kami" data-en="Contact Us">Hubungi Kami</span>
        </a>
      </div>
    </section>
  </main>
</BaseLayout>

<style>
  /* Featured Image */
  .featured-image-container {
    aspect-ratio: 1200 / 630;
  }

  /* Line clamp utilities */
  .line-clamp-1 {
    display: -webkit-box;
    -webkit-line-clamp: 1;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  .line-clamp-2 {
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }
</style>
