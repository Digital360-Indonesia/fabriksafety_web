---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

const blogPosts = await getCollection('blog', ({ data }) => {
  return data.pubDate <= new Date();
});

// Sort by date
blogPosts.sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());

// Featured posts
const featuredPosts = blogPosts.filter(post => post.data.featured);

// Posts per page for load more
const postsPerPage = 9;
const totalPosts = blogPosts.length;

// Default image fallback
const defaultImage = "/images/about/team-consultation.webp";

// Prepare posts data for client-side
const postsData = blogPosts.map(post => ({
  slug: post.slug,
  title: post.data.title,
  titleEn: post.data.titleEn,
  description: post.data.description,
  descriptionEn: post.data.descriptionEn,
  image: post.data.image,
  category: post.data.category,
  author: post.data.author,
  pubDate: post.data.pubDate.toISOString(),
  pubDateFormatted: post.data.pubDate.toLocaleDateString('id-ID', { day: 'numeric', month: 'short', year: 'numeric' }),
  pubDateFull: post.data.pubDate.toLocaleDateString('id-ID', { year: 'numeric', month: 'long', day: 'numeric' })
}));
---

<BaseLayout title="Blog - Fabrik Safety">
  <!-- Hero Section -->
  <section class="bg-gradient-to-r from-primary-600 to-primary-800 text-white py-16 md:py-24 relative overflow-hidden">
    <div class="container-custom">
      <div class="text-center">
        <h1 class="text-4xl md:text-5xl font-bold mb-4"
          data-id="Blog Fabrik Safety"
          data-en="Fabrik Safety Blog"
        >Blog Fabrik Safety</h1>
        <p class="text-lg md:text-xl opacity-90 max-w-2xl mx-auto"
          data-id="Tips, panduan, dan informasi terbaru seputar keselamatan kerja dan pakaian safety"
          data-en="Tips, guides, and latest information about work safety and safety wear"
        >
          Tips, panduan, dan informasi terbaru seputar keselamatan kerja dan pakaian safety
        </p>
      </div>
    </div>
  </section>

  <!-- Featured Posts -->
  {featuredPosts.length > 0 && (
    <section class="py-12 md:py-16 bg-gray-50">
      <div class="container-custom">
        <h2 class="text-2xl md:text-3xl font-bold text-gray-900 mb-8"
          data-id="Artikel Pilihan"
          data-en="Featured Articles"
        >Artikel Pilihan</h2>
        <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
          {featuredPosts.slice(0, 2).map((post) => (
            <a
              href={`/blog/${post.slug}`}
              class="group bg-white rounded-2xl overflow-hidden shadow-sm hover:shadow-xl transition-all duration-300"
            >
              <div class="grid grid-cols-1 md:grid-cols-2 gap-0">
                <div class="relative aspect-square md:aspect-auto overflow-hidden">
                  <img
                    src={post.data.image}
                    alt={post.data.title}
                    class="w-full h-full object-cover group-hover:scale-110 transition-transform duration-500"
                    loading="lazy"
                  />
                </div>
                <div class="p-6 flex flex-col justify-center">
                  <span class="inline-block bg-primary-100 text-primary-700 text-xs font-semibold px-3 py-1 rounded-full mb-3 w-fit">
                    {post.data.category}
                  </span>
                  <h3 class="font-bold text-xl text-gray-900 mb-2 group-hover:text-primary-600 transition-colors"
                    data-id={post.data.title}
                    data-en={post.data.titleEn}
                  >
                    {post.data.title}
                  </h3>
                  <p class="text-sm text-gray-600 mb-4 line-clamp-2"
                    data-id={post.data.description}
                    data-en={post.data.descriptionEn}
                  >
                    {post.data.description}
                  </p>
                  <div class="flex items-center gap-2 text-xs text-gray-500">
                    <span>{post.data.author}</span>
                    <span>•</span>
                    <time datetime={post.data.pubDate.toISOString()}>
                      {post.data.pubDate.toLocaleDateString('id-ID', { year: 'numeric', month: 'long', day: 'numeric' })}
                    </time>
                  </div>
                </div>
              </div>
            </a>
          ))}
        </div>
      </div>
    </section>
  )}

  <!-- All Blog Posts -->
  <section class="py-12 md:py-16">
    <div class="container-custom">
      <h2 class="text-2xl md:text-3xl font-bold text-gray-900 mb-8"
        data-id="Semua Artikel"
        data-en="All Articles"
      >Semua Artikel</h2>

      <!-- Blog Grid Container -->
      <div id="blog-container" class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
        {/* Initial posts will be rendered here by JS */}
      </div>

      <!-- Load More Button -->
      <div id="load-more-container" class="text-center mt-10">
        <button
          id="load-more-btn"
          class="bg-primary-600 text-white font-semibold py-3 px-8 rounded-lg hover:bg-primary-700 transition-all duration-300 inline-flex items-center gap-2"
        >
          <span data-id="Muat Lebih Banyak" data-en="Load More">Muat Lebih Banyak</span>
          <svg class="w-5 h-5 animate-bounce" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 14l-7 7m0 0l-7-7m7 7V3"></path>
          </svg>
        </button>
        <p id="post-counter" class="text-sm text-gray-500 mt-3"></p>
      </div>

      <!-- Loading Spinner -->
      <div id="loading-spinner" class="hidden text-center py-8">
        <div class="inline-block animate-spin rounded-full h-10 w-10 border-4 border-primary-600 border-t-transparent"></div>
        <p class="text-gray-500 mt-2" data-id="Memuat..." data-en="Loading...">Memuat...</p>
      </div>
    </div>
  </section>

  <!-- CTA Section -->
  <section class="py-16 bg-primary-600">
    <div class="container-custom text-center">
      <h2 class="text-3xl font-bold text-white mb-4"
        data-id="Ingin Artikel Terbaru?"
        data-en="Want the Latest Articles?"
      >Ingin Artikel Terbaru?</h2>
      <p class="text-white/90 mb-8 max-w-2xl mx-auto"
        data-id="Hubungi kami untuk konsultasi gratis atau ikuti media sosial kami untuk update terbaru"
        data-en="Contact us for free consultation or follow our social media for the latest updates"
      >
        Hubungi kami untuk konsultasi gratis atau ikuti media sosial kami untuk update terbaru
      </p>
      <a href="https://wa.me/6285111204599" class="bg-white text-primary-600 font-semibold py-3 px-8 rounded-lg hover:bg-gray-100 transition-all duration-300 inline-block">
        <span data-id="Hubungi Kami" data-en="Contact Us">Hubungi Kami</span>
      </a>
    </div>
  </section>
</BaseLayout>

<script define:vars={{postsData, postsPerPage, totalPosts}}>
  // Posts data passed from server
  const allPosts = postsData;
  const perPage = postsPerPage;
  const total = totalPosts;
  let currentPage = 0;

  // DOM Elements
  const container = document.getElementById('blog-container');
  const loadMoreBtn = document.getElementById('load-more-btn');
  const loadMoreContainer = document.getElementById('load-more-container');
  const loadingSpinner = document.getElementById('loading-spinner');
  const postCounter = document.getElementById('post-counter');

  // Get current language
  function getCurrentLang() {
    return localStorage.getItem('preferredLang') || 'id';
  }

  // Create post card HTML
  function createPostCard(post, isMobile = false) {
    const lang = getCurrentLang();
    const title = lang === 'en' && post.titleEn ? post.titleEn : post.title;
    const description = lang === 'en' && post.descriptionEn ? post.descriptionEn : post.description;

    if (isMobile) {
      return `
        <a href="/blog/${post.slug}" class="group block bg-white rounded-2xl overflow-hidden shadow-sm hover:shadow-xl transition-all duration-300">
          <div class="relative aspect-video overflow-hidden">
            <img src="${post.image}" alt="${title}" class="w-full h-full object-cover group-hover:scale-110 transition-transform duration-500" loading="lazy" />
          </div>
          <div class="p-5">
            <span class="inline-block bg-primary-100 text-primary-700 text-xs font-semibold px-3 py-1 rounded-full mb-3">
              ${post.category}
            </span>
            <h3 class="font-bold text-lg text-gray-900 mb-2 group-hover:text-primary-600 transition-colors" data-id="${post.title}" data-en="${post.titleEn}">
              ${title}
            </h3>
            <p class="text-sm text-gray-600 mb-3 line-clamp-2" data-id="${post.description}" data-en="${post.descriptionEn}">
              ${description}
            </p>
            <div class="flex items-center gap-2 text-xs text-gray-500 pt-3 border-t border-gray-100">
              <span>${post.author}</span>
              <span>•</span>
              <time datetime="${post.pubDate}">${post.pubDateFormatted}</time>
            </div>
          </div>
        </a>
      `;
    }

    return `
      <a href="/blog/${post.slug}" class="group bg-white rounded-2xl overflow-hidden shadow-sm hover:shadow-xl transition-all duration-300">
        <div class="relative aspect-video overflow-hidden">
          <img src="${post.image}" alt="${title}" class="w-full h-full object-cover group-hover:scale-110 transition-transform duration-500" loading="lazy" />
        </div>
        <div class="p-5">
          <span class="inline-block bg-primary-100 text-primary-700 text-xs font-semibold px-3 py-1 rounded-full mb-3">
            ${post.category}
          </span>
          <h3 class="font-bold text-lg text-gray-900 mb-2 group-hover:text-primary-600 transition-colors" data-id="${post.title}" data-en="${post.titleEn}">
            ${title}
          </h3>
          <p class="text-sm text-gray-600 mb-3 line-clamp-2" data-id="${post.description}" data-en="${post.descriptionEn}">
            ${description}
          </p>
          <div class="flex items-center gap-2 text-xs text-gray-500 pt-3 border-t border-gray-100">
            <span>${post.author}</span>
            <span>•</span>
            <time datetime="${post.pubDate}">${post.pubDateFormatted}</time>
          </div>
        </div>
      </a>
    `;
  }

  // Load posts
  function loadPosts() {
    const start = currentPage * perPage;
    const end = start + perPage;
    const postsToLoad = allPosts.slice(start, end);
    const isMobile = window.innerWidth < 768;

    // Show loading
    loadingSpinner.classList.remove('hidden');
    loadMoreBtn.classList.add('hidden');

    // Simulate slight delay for smooth UX
    setTimeout(() => {
      postsToLoad.forEach(post => {
        container.innerHTML += createPostCard(post, isMobile);
      });

      currentPage++;
      updateCounter();

      // Hide loading, show button if more posts
      loadingSpinner.classList.add('hidden');

      if (currentPage * perPage >= total) {
        loadMoreContainer.innerHTML = `
          <p class="text-gray-500" data-id="Semua artikel telah ditampilkan" data-en="All articles have been displayed">
            Semua artikel telah ditampilkan
          </p>
        `;
      } else {
        loadMoreBtn.classList.remove('hidden');
      }
    }, 300);
  }

  // Update counter
  function updateCounter() {
    const shown = Math.min(currentPage * perPage, total);
    postCounter.textContent = `Menampilkan ${shown} dari ${total} artikel`;
  }

  // Check if mobile view
  function handleResize() {
    // Reload all posts with correct mobile/desktop layout
    const isMobile = window.innerWidth < 768;
    const currentPosts = currentPage * perPage;
    container.innerHTML = '';

    allPosts.slice(0, currentPosts).forEach(post => {
      container.innerHTML += createPostCard(post, isMobile);
    });
  }

  // Event listeners
  loadMoreBtn.addEventListener('click', loadPosts);

  // Handle resize with debounce
  let resizeTimer;
  window.addEventListener('resize', () => {
    clearTimeout(resizeTimer);
    resizeTimer = setTimeout(handleResize, 250);
  });

  // Initial load
  loadPosts();

  // Event delegation for dynamically added post cards
  container.addEventListener('click', (e) => {
    const card = e.target.closest('a[href^="/blog/"]');
    if (card) {
      // Let the default anchor behavior work
      // This ensures the link works properly
    }
  });
</script>
