---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { portfolios } from '../../data/portfolio';
---

<BaseLayout
  title="Portfolio - Fabrik Safety"
  description="Lihat portfolio proyek seragam safety dan wearpack dari Fabrik Safety. Dipercaya oleh perusahaan-perusahaan besar di Indonesia untuk menyediakan pakaian safety berkualitas tinggi."
  image="/images/og-image.webp"
>
  <!-- Hero Section -->
  <section class="bg-gradient-to-r from-primary-600 to-primary-800 text-white py-16 md:py-24 relative overflow-hidden">
    <div class="container-custom">
      <div class="text-center">
        <h1 class="text-4xl md:text-5xl font-bold mb-4"
          data-id="Portfolio Kami"
          data-en="Our Portfolio"
        >Portfolio Kami</h1>
        <p class="text-lg md:text-xl opacity-90 max-w-2xl mx-auto"
          data-id="Dipercaya oleh perusahaan-perusahaan besar untuk menyediakan pakaian safety berkualitas tinggi"
          data-en="Trusted by major companies to provide high-quality safety wear"
        >
          Dipercaya oleh perusahaan-perusahaan besar untuk menyediakan pakaian safety berkualitas tinggi
        </p>
      </div>
    </div>
  </section>

  <!-- Portfolio Grid -->
  <section id="portfolio" class="py-16 md:py-24 bg-gray-50 isolate">
    <div class="container-custom">
      <div class="text-center space-y-4 mb-12">
        <h2 class="section-title"
          data-id="Portfolio Klien"
          data-en="Client Portfolio"
        >Portfolio Klien</h2>
        <p class="section-subtitle max-w-2xl mx-auto"
          data-id="Dipercaya oleh perusahaan-perusahaan besar untuk menyediakan pakaian safety berkualitas tinggi"
          data-en="Trusted by major companies to provide high-quality safety wear"
        >
          Dipercaya oleh perusahaan-perusahaan besar untuk menyediakan pakaian safety berkualitas tinggi
        </p>
      </div>

      <!-- Mobile Slider -->
      <div class="md:hidden relative mb-8 pointer-events-auto">
        <div id="portfolio-slider" class="flex gap-4 overflow-x-auto snap-x snap-mandatory scrollbar-hide" style="scroll-snap-type: x mandatory; -webkit-overflow-scrolling: touch;">
          {portfolios.map((item) => (
            <a
              href={`/portfolio/${item.slug}`}
              class="flex-shrink-0 w-72 snap-center group bg-white rounded-2xl overflow-hidden shadow-sm hover:shadow-xl transition-all duration-300"
            >
              <div class="relative aspect-square bg-gray-100 overflow-hidden">
                <img
                  src={item.mainImage}
                  alt={item.productName}
                  class="w-full h-full object-cover group-hover:scale-110 transition-transform duration-500"
                  loading="lazy"
                />
                <div class="absolute bottom-0 left-0 right-0 bg-primary-600/80 p-4 translate-y-full group-hover:translate-y-0 group-active:translate-y-0 transition-transform duration-300">
                  <h3 class="text-white font-bold text-center">{item.clientName}</h3>
                </div>
              </div>
              <div class="p-5">
                <h3 class="font-bold text-gray-900 mb-1 group-hover:text-primary-600 transition-colors"
                  data-id={item.productName}
                  data-en={item.productNameEn}
                >
                  {item.productName}
                </h3>
                <p class="text-sm text-gray-500 mb-3 line-clamp-2"
                  data-id={item.description}
                  data-en={item.descriptionEn}
                >{item.description}</p>
                <div class="flex items-center justify-between pt-3 border-t border-gray-100">
                  <span class="text-xs text-gray-400"
                    data-id="Klien"
                    data-en="Client"
                  >Klien</span>
                  <img
                    src={item.clientLogo}
                    alt={item.clientName}
                    class="h-8 w-auto object-contain"
                  />
                </div>
              </div>
            </a>
          ))}
        </div>

        <!-- Slider Indicators -->
        <div class="flex justify-center gap-2 mt-4">
          {portfolios.map((_, index) => (
            <button
              data-portfolio-dot={index}
              class="w-2 h-2 rounded-full bg-gray-300 transition-all duration-300"
              style={`width: ${index === 0 ? '24px' : '8px'}`}
            />
          ))}
        </div>
      </div>

      <!-- Desktop Grid -->
      <div class="hidden md:grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-6 relative z-10">
        {portfolios.map((item) => (
          <a
            href={`/portfolio/${item.slug}`}
            class="group bg-white rounded-2xl overflow-hidden shadow-sm hover:shadow-xl transition-all duration-300"
          >
            <div class="relative aspect-square bg-gray-100 overflow-hidden">
              <img
                src={item.mainImage}
                alt={item.productName}
                class="w-full h-full object-cover group-hover:scale-110 transition-transform duration-500"
                loading="lazy"
              />
              <div class="absolute bottom-0 left-0 right-0 bg-primary-600/80 p-4 translate-y-full group-hover:translate-y-0 group-active:translate-y-0 transition-transform duration-300">
                <h3 class="text-white font-bold text-center">{item.clientName}</h3>
              </div>
            </div>
            <div class="p-5">
              <h3 class="font-bold text-gray-900 mb-1 group-hover:text-primary-600 transition-colors"
                data-id={item.productName}
                data-en={item.productNameEn}
              >
                {item.productName}
              </h3>
              <p class="text-sm text-gray-500 mb-3 line-clamp-2"
                data-id={item.description}
                data-en={item.descriptionEn}
              >{item.description}</p>
              <div class="flex items-center justify-between pt-3 border-t border-gray-100">
                <span class="text-xs text-gray-400"
                  data-id="Klien"
                  data-en="Client"
                >Klien</span>
                <img
                  src={item.clientLogo}
                  alt={item.clientName}
                  class="h-8 w-auto object-contain"
                />
              </div>
            </div>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- CTA Section -->
  <section class="py-16 bg-primary-600">
    <div class="container-custom text-center">
      <h2 class="text-3xl font-bold text-white mb-4"
        data-id="Ingin Proyek Seperti Ini?"
        data-en="Want a Project Like This?"
      >Ingin Proyek Seperti Ini?</h2>
      <p class="text-white/90 mb-8 max-w-2xl mx-auto"
        data-id="Hubungi kami sekarang untuk konsultasi gratis tentang kebutuhan pakaian safety perusahaan Anda"
        data-en="Contact us now for a free consultation about your company's safety apparel needs"
      >
        Hubungi kami sekarang untuk konsultasi gratis tentang kebutuhan pakaian safety perusahaan Anda
      </p>
      <a href="https://wa.me/6285111204599" class="bg-white text-primary-600 font-semibold py-3 px-8 rounded-lg hover:bg-gray-100 transition-all duration-300 inline-block">
        <span data-id="Hubungi Kami" data-en="Contact Us">Hubungi Kami</span>
      </a>
    </div>
  </section>
</BaseLayout>

<style>
  .scrollbar-hide {
    -ms-overflow-style: none;
    scrollbar-width: none;
  }
  .scrollbar-hide::-webkit-scrollbar {
    display: none;
  }
</style>

<script>
  function initPortfolioSlider() {
    const slider = document.getElementById('portfolio-slider');
    const dots = document.querySelectorAll('[data-portfolio-dot]');

    if (slider && dots.length > 0) {
      slider.addEventListener('scroll', () => {
        const scrollLeft = slider.scrollLeft;
        const cardWidth = 288 + 16; // card width + gap
        const activeIndex = Math.round(scrollLeft / cardWidth);

        dots.forEach((dot, index) => {
          if (index === activeIndex) {
            dot.style.width = '24px';
            dot.style.backgroundColor = '#0678b3';
          } else {
            dot.style.width = '8px';
            dot.style.backgroundColor = '#d1d5db';
          }
        });
      });

      // Click handlers for dots
      dots.forEach((dot, index) => {
        dot.addEventListener('click', () => {
          const cardWidth = 288 + 16;
          slider.scrollTo({
            left: index * cardWidth,
            behavior: 'smooth'
          });
        });
      });
    }
  }

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', initPortfolioSlider);
  } else {
    initPortfolioSlider();
  }
</script>
