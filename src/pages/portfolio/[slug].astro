---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { portfolios, getPortfolioBySlug, getAllPortfolioSlugs } from '../../data/portfolio';

export function getStaticPaths() {
  const slugs = getAllPortfolioSlugs();
  return slugs.map(slug => ({
    params: { slug },
  }));
}

const { slug } = Astro.params;
const portfolio = getPortfolioBySlug(slug as string);

if (!portfolio) {
  return Astro.redirect('/404');
}

// Get related portfolios (same category, exclude current)
const relatedPortfolios = portfolios
  .filter(p => p.category === portfolio.category && p.id !== portfolio.id)
  .slice(0, 3);
---

<BaseLayout title={`${portfolio.productName} - Fabrik Safety Portfolio`}>
  <!-- Breadcrumb -->
  <section class="bg-gray-100 py-4">
    <div class="container-custom">
      <nav class="flex items-center space-x-2 text-sm">
        <a href="/" class="text-gray-500 hover:text-primary-600"
          data-id="Beranda"
          data-en="Home"
        >Beranda</a>
        <span class="text-gray-400">/</span>
        <a href="/portfolio" class="text-gray-500 hover:text-primary-600"
          data-id="Portfolio"
          data-en="Portfolio"
        >Portfolio</a>
        <span class="text-gray-400">/</span>
        <span class="text-gray-900 font-medium">{portfolio.productName}</span>
      </nav>
    </div>
  </section>

  <!-- Portfolio Detail -->
  <section class="py-12 md:py-16">
    <div class="container-custom">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-8 lg:gap-12">
        <!-- Image Gallery -->
        <div class="space-y-4">
          <!-- Main Image -->
          <div class="relative aspect-square rounded-2xl overflow-hidden bg-gray-100">
            <img
              id="main-image"
              src={portfolio.mainImage}
              alt={portfolio.productName}
              class="w-full h-full object-cover"
            />
          </div>
        </div>

        <!-- Content -->
        <div class="space-y-6">
          <!-- Category Badge -->
          <span class="inline-block bg-primary-100 text-primary-700 text-sm font-semibold px-4 py-1 rounded-full">
            {portfolio.category}
          </span>

          <!-- Title -->
          <h1 class="text-3xl md:text-4xl font-bold text-gray-900"
            data-id={portfolio.productName}
            data-en={portfolio.productNameEn}
          >{portfolio.productName}</h1>

          <!-- Meta Info -->
          <div class="flex flex-wrap gap-4 text-sm text-gray-600">
            <div class="flex items-center gap-2">
              <svg class="w-5 h-5 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-5 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4"/>
              </svg>
              <span>{portfolio.clientName}</span>
            </div>
            <div class="flex items-center gap-2">
              <svg class="w-5 h-5 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"/>
              </svg>
              <span>{portfolio.year}</span>
            </div>
          </div>

          <!-- Description -->
          <div class="prose prose-gray max-w-none">
            <p class="text-gray-600 text-lg leading-relaxed"
              data-id={portfolio.description}
              data-en={portfolio.descriptionEn}
            >{portfolio.description}</p>
          </div>

          <!-- Tags -->
          <div class="flex flex-wrap gap-2">
            {portfolio.tags.map(tag => (
              <span class="bg-gray-100 text-gray-600 text-sm px-3 py-1 rounded-full">
                #{tag}
              </span>
            ))}
          </div>

          <!-- CTA -->
          <div class="pt-6 border-t border-gray-200">
            <p class="text-gray-600 mb-4"
              data-id="Tertarik dengan proyek serupa? Hubungi kami untuk konsultasi."
              data-en="Interested in a similar project? Contact us for consultation."
            >Tertarik dengan proyek serupa? Hubungi kami untuk konsultasi.</p>
            <a
              href={`https://wa.me/6285111204599?text=Halo, saya tertarik dengan proyek ${encodeURIComponent(portfolio.productName)}. Bisa info lebih lanjut?`}
              class="btn-primary inline-flex items-center gap-2"
              target="_blank"
            >
              <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24">
                <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>
              </svg>
              <span data-id="Pesan Sekarang" data-en="Order Now">Pesan Sekarang</span>
            </a>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Related Portfolios -->
  {relatedPortfolios.length > 0 && (
    <section class="py-12 md:py-16 bg-gray-50">
      <div class="container-custom">
        <h2 class="text-2xl font-bold text-gray-900 mb-8"
          data-id="Proyek Terkait"
          data-en="Related Projects"
        >Proyek Terkait</h2>
        <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
          {relatedPortfolios.map((related) => (
            <a
              href={`/portfolio/${related.slug}`}
              class="group bg-white rounded-2xl overflow-hidden shadow-sm hover:shadow-lg transition-all duration-300"
            >
              <div class="relative aspect-square overflow-hidden">
                <img
                  src={related.mainImage}
                  alt={related.productName}
                  class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-300"
                />
              </div>
              <div class="p-4">
                <h3 class="font-semibold text-gray-900 group-hover:text-primary-600 transition-colors"
                  data-id={related.productName}
                  data-en={related.productNameEn}
                >{related.productName}</h3>
                <p class="text-sm text-gray-500">{related.clientName}</p>
              </div>
            </a>
          ))}
        </div>
      </div>
    </section>
  )}
</BaseLayout>
